<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>FlashFlow — All Cards</title>
  <style>
    body { font-family: -apple-system, system-ui, sans-serif; max-width: 720px; margin: 2rem auto; padding: 0 1rem; line-height: 1.5; color: #222; }
    h1 { font-size: 1.5rem; margin-bottom: 1rem; }
    ul { list-style: none; padding: 0; }
    li { padding: 0.75rem 0; border-bottom: 1px solid #eee; }
    a { color: #0066cc; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .meta { font-size: 0.85rem; color: #666; }
  </style>
</head>
<body>
  <h1>All Cards (<%= cards.length %>)</h1>
  <ul>
    <% cards.forEach(function(card) { %>
      <li>
        <a href="/cards/<%= card.id %>"><%= card.question %></a>
        <div class="meta"><%= card.subject_title %> · <%= card.chapter_title %></div>
      </li>
    <% }); %>
  </ul>
</body>
</html>